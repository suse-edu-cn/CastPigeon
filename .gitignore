# ====================================================================
# 1. macOS 系统级规范忽略
# ====================================================================
.DS_Store
**/.DS_Store
*.icu
.AppleDouble
.LSOverride

# ====================================================================
# 2. IDE 与工程配置文件忽略（针对 IntelliJ, Android Studio, Xcode）
# ====================================================================
*.iml
*.ipr
*.iws
.idea/
.kotlin/
**/.kotlin/
.gradle/
**/.gradle/
/local.properties
.captures/
.externalNativeBuild/
.cxx/

# ====================================================================
# 3. 核心构建产物忽略（针对 Gradle, Kotlin Multiplatform）
# ====================================================================
build/
**/build/
.ncBuildConfig/

# ====================================================================
# 4. macOS / iOS / Xcode 特异性忽略（防止 Swift 编译中间产物穿透）
# ====================================================================
# 忽略 Xcode 所有的本地用户数据与衍生数据
**/xcuserdata/
**/DerivedData/
**/Build/
**/.build/
**/.swiftpm/

# 忽略 Xcode 自动化管理文件，但保留核心工程结构文件
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings
**/Pods/

# ====================================================================
# 5. 其他依赖组件忽略
# ====================================================================
node_modules/

# Flutter local/generated workspace state
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/*.iml

# ====================================================================
# 6. Android / Kotlin 编译及发布产物
# ====================================================================
*.apk
*.ap_
*.aab
*.dex
*.class
*.dm
bin/
gen/
out/
captures/
release/
debug/

# ====================================================================
# 7. CI / 本地打包发布产物
# ====================================================================
# CI 会在运行时重新生成 dist 目录，仓库只保留构建脚本和工作流配置。
dist/
*.zip
*.dmg
*.pkg
*.ipa
*.xcarchive
*.dSYM
*.sha256
*.xcresult

# ====================================================================
# 8. Python 脚本缓存
# ====================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# ====================================================================
# 9. 常见临时文件
# ====================================================================
*.log
*.tmp
*.temp
*~
